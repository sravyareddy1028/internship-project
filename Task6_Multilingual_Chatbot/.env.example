# Copy this file to .env and add your OpenRouter key.
USE_OPENROUTER=true
OPENROUTER_API_KEY=sk-or-your-key-here

# openrouter/auto lets OpenRouter pick a model. You can replace it with a specific model ID.
OPENROUTER_MODEL=openrouter/auto

# Optional metadata shown in OpenRouter activity.
OPENROUTER_SITE_URL=http://127.0.0.1:8000
OPENROUTER_APP_NAME=Multilingual Internship Chatbot